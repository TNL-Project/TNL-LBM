<?xml version="1.0"?>
<adios-config>
    <io name="Output">
        <!-- See https://adios2.readthedocs.io/en/latest/engines/engines.html for all engine parameters. -->
        <engine type="BP5">
            <!-- SST engine parameters -->
            <parameter key="RendezvousReaderCount" value="1"/>
            <parameter key="QueueLimit" value="1"/>
            <parameter key="QueueFullPolicy" value="Block"/>
            <parameter key="DataTransport" value="WAN"/>
            <!-- BP4/SST engine parameters -->
            <parameter key="OpenTimeoutSecs" value="60.0"/>
            <!-- BP3/BP4/BP5 engine parameters -->
            <!--<parameter key="NumAggregators" value="1"/>-->
            <!--<parameter key="AggregatorRatio" value="4"/>-->
            <!-- BP5 engine parameters -->
            <parameter key="AggregationType" value="TwoLevelShm"/>
            <parameter key="MaxShmSize" value="4GB"/>
            <parameter key="AsyncWrite" value="true"/>
        </engine>
    </io>
</adios-config>
